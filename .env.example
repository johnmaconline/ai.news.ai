# ****************************************************************************************
# Daily AI Feed - Local Environment Template
# ****************************************************************************************
# 1) Copy this file to `.env`
# 2) Fill in values
# 3) Keep `.env` local only (already gitignored)

# -------------------------
# Feed generation
# -------------------------
FEED_TIMEZONE=America/New_York

# -------------------------
# OpenAI (optional)
# -------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Auto-select lowest estimated-cost model for each LLM operation.
OPENAI_MINIMIZE_COST=1
# Optional comma-separated allowlist for auto-selection candidates.
# Example: gpt-5-nano,gpt-5-mini,gpt-4o-mini
OPENAI_MODEL_CANDIDATES=
# Optional model temperature (if supported by selected model).
OPENAI_TEMPERATURE=
# Optional override path for global workflow guidance prompt.
WORKFLOW_PROMPT_FILE=prompts/workflow.md

# LLM curation tuning (optional)
LLM_CURATION_MAX_CANDIDATES=20
LLM_CURATION_WEIGHT=1.3
LLM_CURATION_EXCLUDE_PENALTY=8.0

# -------------------------
# X / Twitter source ingestion (optional)
# -------------------------
X_BEARER_TOKEN=

# -------------------------
# LinkedIn source ingestion (optional)
# -------------------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_API_VERSION=202503
# This is now read automatically by the LinkedIn fetcher and overrides
# `author_urn` in config/sources.yaml when present.
LINKEDIN_AUTHOR_URN=urn:li:organization:000000

# -------------------------
# Discord source onboarding (optional)
# -------------------------
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated channel IDs to mine.
DISCORD_CHANNEL_IDS=
# Default read-only install scopes and permissions.
DISCORD_BOT_SCOPES=bot,applications.commands
DISCORD_BOT_PERMISSIONS=66560

# -------------------------
# GitHub automation bootstrap (optional, for script-based setup)
# -------------------------
GITHUB_OWNER=johnmaconline
GITHUB_REPO=ai.news.ai
# Token should have permission to manage repo secrets/variables and workflow runs.
GITHUB_TOKEN=

# -------------------------
# Email subscriptions (phase 1)
# -------------------------
# Static site subscribe form POST target (used by renderer).
# Example: https://newsletter-api.yourdomain.com/subscribe
NEWSLETTER_SUBSCRIBE_ENDPOINT=
# Subscription service base URL used in confirm/unsubscribe emails.
# Example: https://newsletter-api.yourdomain.com
SUBSCRIPTION_PUBLIC_BASE_URL=http://localhost:8090
# SQLite path for subscriber storage.
SUBSCRIPTION_DB_PATH=data/subscribers.db
# Comma-separated CORS origins for subscribe API.
# Example: https://johnmaconline.github.io
NEWSLETTER_CORS_ORIGINS=*
# Use a long random value in production.
SUBSCRIPTION_TOKEN_SECRET=

# Resend email delivery for confirmation emails.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_REPLY_TO=
